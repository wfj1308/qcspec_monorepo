{
  "name": "qcspec",
  "version": "0.1.0",
  "private": true,
  "description": "QCSpec · 工程质检平台 · GitPeg v:// 生态",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev":     "turbo run dev",
    "build":   "turbo run build",
    "test":    "turbo run test",
    "lint":    "turbo run lint",
    "db:push": "supabase db push",
    "db:reset":"supabase db reset"
  },
  "devDependencies": {
    "turbo":      "^1.13.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
