# Slim backend environment template.
# Runtime scope: auth + permission proxy + upload proxy.

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Basic runtime
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=true

# Auth tuning (optional)
AUTH_TOKEN_SECRET=
AUTH_REVOKE_FP_SECRET=
AUTH_BCRYPT_ROUNDS=12
AUTH_FAIL_CLOSED_REVOKE=true
AUTH_ALLOW_MISSING_REVOKE_TABLE=true

# Permission proxy (teammate-owned API gateway)
DTOROLE_UPSTREAM_BASE_URL=
DTOROLE_UPSTREAM_BEARER_TOKEN=
DTOROLE_UPSTREAM_API_KEY=
DTOROLE_PROXY_TIMEOUT_S=12

# Upload proxy (teammate-owned API gateway)
# Falls back to DTOROLE_UPSTREAM_BASE_URL when empty.
UPLOAD_UPSTREAM_BASE_URL=
UPLOAD_UPSTREAM_BEARER_TOKEN=
UPLOAD_UPSTREAM_API_KEY=
UPLOAD_PROXY_TIMEOUT_S=20
