# QCSpec · 环境变量配置
# 复制为 .env 填入真实值

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API ──
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=true

# ── 报告存储 ──
REPORT_OUTPUT_DIR=./reports
TEMPLATE_DIR=./templates

# ── GitPeg v:// ──
GITPEG_API_URL=https://api.gitpeg.dev
GITPEG_TOKEN=your-gitpeg-token
GITPEG_AUTOREG_NAMESPACE=v://cn.zhongbei/
GITPEG_SUPABASE_URL=https://your-project.supabase.co
GITPEG_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
V_ROOT_URI=v://cn.中北/

# ── 后期接入 ──
# WECHAT_APPID=
# WECHAT_SECRET=

# GitPeg Registrar (OAuth Partner Flow)
GITPEG_REGISTRAR_BASE_URL=https://gitpeg.cn
GITPEG_PARTNER_CODE=wastewater-site
GITPEG_INDUSTRY_CODE=wastewater
GITPEG_CLIENT_ID=ptn_wastewater_001
GITPEG_CLIENT_SECRET=wastewater-secret-001
GITPEG_REGISTRATION_MODE=DOMAIN
GITPEG_RETURN_URL=http://localhost:3000/gitpeg/callback
GITPEG_WEBHOOK_URL=http://localhost:8000/v1/projects/gitpeg/webhook
GITPEG_WEBHOOK_SECRET=
GITPEG_MODULE_CANDIDATES=proof,utrip,openapi

# Proof-UTXO runtime
PROOF_UTXO_AUTO_CONSUME=true
PROOF_UTXO_GITPEG_ANCHOR_ENABLED=false
GITPEG_PROOF_ANCHOR_PATH=/api/v1/proof/anchor
GITPEG_PROOF_ANCHOR_TOKEN=
GITPEG_PROOF_ANCHOR_TIMEOUT_S=6

# Verify mock anchor endpoint guard (default disabled)
VERIFY_ENABLE_MOCK_ANCHOR=false
VERIFY_MOCK_ANCHOR_INTERNAL_KEY=
