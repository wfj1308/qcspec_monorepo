# QCSpec · 环境变量配置
# 复制为 .env 填入真实值

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API ──
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=true

# ── 报告存储 ──
REPORT_OUTPUT_DIR=./reports
TEMPLATE_DIR=./templates

# ── GitPeg v:// ──
GITPEG_API_URL=https://api.gitpeg.dev
GITPEG_TOKEN=your-gitpeg-token
GITPEG_AUTOREG_NAMESPACE=v://cn.zhongbei/
GITPEG_SUPABASE_URL=https://your-project.supabase.co
GITPEG_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
V_ROOT_URI=v://cn.中北/

# ── 后期接入 ──
# WECHAT_APPID=
# WECHAT_SECRET=
